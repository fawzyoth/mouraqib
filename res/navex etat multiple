Exemple d'envoi curl (tracking multiple) :

$ch = curl_init();

// Option 1 : tableau de codes PHP
$codes_array = ['311156852841', '957742017491', '814647729631'];
$codes_string = implode(', ', $codes_array);

$post_data = "codes=" . urlencode($codes_string);

curl_setopt($ch, CURLOPT_URL, "https://app.navex.tn/api/pageshopa-etat-7AL8W3QCZOPA0WH34IOEG7GA445OX0CI/v1/post.php");
curl_setopt($ch, CURLOPT_POST, 1);
curl_setopt($ch, CURLOPT_POSTFIELDS, $post_data);
curl_setopt($ch, CURLOPT_RETURNTRANSFER, TRUE);
curl_setopt($ch, CURLOPT_HTTPAUTH, CURLAUTH_BASIC);
curl_setopt($ch, CURLOPT_FOLLOWLOCATION, 1);

$server_output = curl_exec($ch);

if (curl_errno($ch)) {
    echo "Erreur cURL : " . curl_error($ch);
    curl_close($ch);
    exit;
}

curl_close($ch);

// Traitement de la réponse
$result = json_decode($server_output, true);

                                
